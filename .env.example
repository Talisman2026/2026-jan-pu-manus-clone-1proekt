# Database
DATABASE_URL=postgresql+asyncpg://agentflow:password@postgres:5432/agentflow
POSTGRES_USER=agentflow
POSTGRES_PASSWORD=change_me_in_production

# Auth
JWT_SECRET=change_me_to_32_byte_random_string

# E2B — создание sandbox'ов
# https://e2b.dev/dashboard → API Keys
E2B_API_KEY=e2b_your_key_here

# OpenAI — НАШ ключ, только для estimation (GPT-4o-mini)
# Ключ пользователя вводится в UI → НЕ хранится здесь
OPENAI_API_KEY=sk-your_key_here

# Firecrawl — web search внутри sandbox
# https://firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=fc-your_key_here
